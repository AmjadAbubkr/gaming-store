rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Anyone can create a user doc during registration
      allow create: if isAuth() && request.auth.uid == userId;
      // Users can only read/update their own profile. Admins can read all.
      allow read, update: if (isAuth() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      // Anyone (even guests) can read products
      allow read: if true;
      // Only admins can modify the catalog
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Users can only read their own orders. Admins can read all.
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      // Users can create orders for themselves
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Only admins can update (e.g., change status) or delete orders
      allow update, delete: if isAdmin();
    }
  }
}
